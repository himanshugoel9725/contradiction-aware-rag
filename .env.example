# Copy this file to .env and fill in your actual values.
# The .env file is gitignored — never commit real keys.

# ─── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Optional ─────────────────────────────────────────────────────────────────
# Anthropic API key (for Claude models if added later)
ANTHROPIC_API_KEY=sk-ant-...

# NCBI email — required for GRADE quality classifier (PubMed lookups)
# Register free at https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your@email.com
